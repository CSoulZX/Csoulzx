-- ==========================================
-- LOGIKA PENDUKUNG
-- ==========================================
local function IsScaleMatch(sAttr)
    if _G.SelectedScales["All"] then return true end
    local s = _G.SelectedScales
    if s["Lil Baby"] and (sAttr >= 0.1 and sAttr <= 0.35) then return true end
    if s["Baby"] and (sAttr >= 0.34 and sAttr <= 0.65) then return true end
    if s["Mini"] and (sAttr >= 0.66 and sAttr <= 0.85) then return true end
    if s["Normal"] and (sAttr >= 0.86 and sAttr <= 1.2) then return true end
    if s["Big"] and (sAttr >= 1.2 and sAttr <= 1.95) then return true end
    if s["Colossal"] and (sAttr >= 1.96 and sAttr <= 3.0) then return true end
    return false
end

local function GetUniversalCount(m)
    if not m then return nil end
    for _, v in pairs(m:GetDescendants()) do
        if v:IsA("ProximityPrompt") then
            local t = (v.ActionText or "") .. (v.ObjectText or "")
            local c, max = t:match("(%d+)/(%d+)")
            if c then return tonumber(c), tonumber(max) end
        end
    end
    return nil
end

local function FindMachine(name)
    for _, v in pairs(workspace:GetDescendants()) do
        if (v.Name == name or v.Name == name.."Machine" or v.Name == name.." Machine") and (v:IsA("Model") or v:IsA("BasePart") or v:IsA("Folder")) then
            if GetUniversalCount(v) then
                return v
            end
        end
    end
    return nil
end

local function SuperScanUnit(activeMachine)
    local char = game.Players.LocalPlayer.Character
    local backpack = game.Players.LocalPlayer:FindFirstChild("Backpack")
    local function IsValid(item)
        if item and item:IsA("Tool") then
            local bName = tostring(item:GetAttribute("BrainrotName") or ""):lower()
            local sAttr = tonumber(item:GetAttribute("Scale")) or 0
            
            if not IsScaleMatch(sAttr) then return false end
            
            if activeMachine == "Drillforge" and _G.SelectedUnitName ~= "All Units" then
                return not string.find(bName, _G.SelectedUnitName:lower())
            else
                return (_G.SelectedUnitName == "All Units" or string.find(bName, _G.SelectedUnitName:lower()))
            end
        end
        return false
    end
    if char and IsValid(char:FindFirstChildOfClass("Tool")) then return char:FindFirstChildOfClass("Tool") end
    if backpack then for _, i in pairs(backpack:GetChildren()) do if IsValid(i) then return i end end end
    return nil
end

-- ==========================================
-- MAIN AUTO FUSE LOOP
-- ==========================================
local function StartAutoFuse()
    while _G.AutoFuse do
        local char = game.Players.LocalPlayer.Character
        local humanoid = char and char:FindFirstChild("Humanoid")
        local hrp = char and char:FindFirstChild("HumanoidRootPart")
        if not hrp or not humanoid or humanoid.Health <= 0 then task.wait(1) continue end

        local activeMachineName = nil
        if _G.SelectedMachines["All"] then
            for _, name in pairs(machineList) do
                local mObj = FindMachine(name)
                if mObj then activeMachineName = name break end
            end
        else
            for name, sel in pairs(_G.SelectedMachines) do if sel then activeMachineName = name break end end
        end

        if not activeMachineName then task.wait(1) continue end

        local machineObj = FindMachine(activeMachineName)
        local targetPos = machineObj and (machineObj:IsA("Model") and machineObj:GetPivot().Position or (machineObj:IsA("BasePart") and machineObj.Position or machineObj:FindFirstChildWhichIsA("BasePart", true).Position))

        if not targetPos then task.wait(1) continue end

        local count, maxCount = GetUniversalCount(machineObj)
        if count == nil then task.wait(0.1) continue end

        local distH = Vector2.new(hrp.Position.X - targetPos.X, hrp.Position.Z - targetPos.Z).Magnitude
        
        -- LOGIKA MOVE & ARRIVAL TRACKING
        if distH > 5 then
            arrivalTime = 0 -- Reset timer jika masih dalam perjalanan
            TweenService:Create(hrp, TweenInfo.new(1), {CFrame = CFrame.new(hrp.Position.X, targetPos.Y + _G.FlyHeight, hrp.Position.Z)}):Play()
            task.wait(1.1)
            TweenService:Create(hrp, TweenInfo.new(distH/_G.TweenSpeed, Enum.EasingStyle.Linear), {CFrame = CFrame.new(targetPos.X, targetPos.Y + _G.FlyHeight, targetPos.Z)}):Play()
            task.wait((distH/_G.TweenSpeed) + 0.2)
            TweenService:Create(hrp, TweenInfo.new(0.8), {CFrame = CFrame.new(targetPos.X, targetPos.Y + 3, targetPos.Z)}):Play()
            task.wait(0.9)
            
            if char:FindFirstChildOfClass("Tool") then 
                char.Humanoid:UnequipTools() 
                task.wait(0.2)
            end
        else
            -- Jika sudah di mesin, mulai hitung waktu
            if arrivalTime == 0 then arrivalTime = tick() end
        end

        -- LOGIKA AUTO RESET (Jika 5 detik tidak menemukan unit)
        local tool = SuperScanUnit(activeMachineName)
        if arrivalTime ~= 0 and (tick() - arrivalTime) > 5 and not tool then
            humanoid.Health = 0 -- Restart Karakter
            arrivalTime = 0
            task.wait(2)
            continue
        end

        if count == 0 then
            if tool then 
                arrivalTime = 0 -- Reset timer jika tool ditemukan
                tool.Parent = char 
                task.wait(0.2) 
                VirtualInputManager:SendKeyEvent(true, Enum.KeyCode.E, false, game) 
                task.wait(0.05) 
                VirtualInputManager:SendKeyEvent(false, Enum.KeyCode.E, false, game) 
            end
        elseif count < (maxCount - 1) then
            if char:FindFirstChildOfClass("Tool") then char.Humanoid:UnequipTools() end
            task.wait(0.1) VirtualInputManager:SendKeyEvent(true, Enum.KeyCode.E, false, game) task.wait(0.05) VirtualInputManager:SendKeyEvent(false, Enum.KeyCode.E, false, game) task.wait(3) 
        elseif count == (maxCount - 1) then
            VirtualInputManager:SendKeyEvent(true, Enum.KeyCode.F, false, game) task.wait(0.05) VirtualInputManager:SendKeyEvent(false, Enum.KeyCode.F, false, game) task.wait(2.5) 
            if char:FindFirstChildOfClass("Tool") then char.Humanoid:UnequipTools() end
        end
        task.wait(1) 
    end
end

